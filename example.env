# Copy to .env and fill in real values. Do NOT commit .env.

# --- Database (Prisma / MySQL) ---
# For local development with the bundled docker-compose db:
#   mysql://root:root@localhost:3306/vision
DATABASE_URL=mysql://user:password@host:3306/database

# --- Auth (NextAuth + Google OAuth) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-strong-secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# --- Public config (inlined into the client bundle at build time) ---
NEXT_PUBLIC_NEXTAUTH_URL=http://localhost:3000
